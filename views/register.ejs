<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f8f9fa;
}

.card-register{
    max-width:450px;
    margin:auto;
    margin-top:8vh;
}

.btn-purple{
    background:#6f42c1;
    color:white;
}

</style>

<title>Cadastro</title>
</head>
<body>

<div class="container">

    <div class="card shadow card-register">

        <div class="card-body">

            <h2 class="text-center mb-4">
                Criar Conta
            </h2>

            <form action="/auth/register" method="POST">

                <div class="mb-3">
                    <label>Nome</label>
                    <input
                        type="text"
                        name="name"
                        class="form-control"
                        required>
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input
                        type="email"
                        name="email"
                        class="form-control"
                        required>
                </div>

                <div class="mb-3">
                    <label>Senha</label>
                    <input
                        type="password"
                        name="password"
                        class="form-control"
                        required>
                </div>

                <button class="btn btn-purple w-100">
                    Cadastrar
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>