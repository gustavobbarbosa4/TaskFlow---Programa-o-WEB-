<!DOCTYPE html>

<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Editar Usuário</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>
<body>

<div class="container mt-5">

<h2 class="mb-4">
    Editar Usuário
</h2>

<form action="/admin/users/edit/<%= user.id %>" method="POST">

    <div class="mb-3">

        <label class="form-label">
            Nome
        </label>

        <input
            type="text"
            name="nome"
            class="form-control"
            value="<%= user.nome %>"
            required>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Email
        </label>

        <input
            type="email"
            name="email"
            class="form-control"
            value="<%= user.email %>"
            required>

    </div>

    <div class="mb-3">

        <label class="form-label">
            Nível de acesso
        </label>

        <select
            name="nivel_acesso"
            class="form-select">

            <option
                value="user"
                <%= user.nivel_acesso === 'user' ? 'selected' : '' %>>
                Usuário
            </option>

            <option
                value="admin"
                <%= user.nivel_acesso === 'admin' ? 'selected' : '' %>>
                Administrador
            </option>

        </select>

    </div>

    <button
        type="submit"
        class="btn btn-success">

        Salvar

    </button>

    <a
        href="/admin/users"
        class="btn btn-secondary">

        Cancelar

    </a>

</form>

</div>

</body>
</html>
